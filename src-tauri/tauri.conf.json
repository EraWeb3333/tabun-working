{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "たぶん作業中",
  "version": "1.0.0",
  "identifier": "com.erako.tabunworking",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "たぶん作業中",
        "width": 560,
        "height": 720,
        "resizable": false,
        "decorations": true,
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "Japanese"
        ]
      }
    }
  }
}
